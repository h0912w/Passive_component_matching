# Passive Component Matching Tool - API Keys
# ================================================
# 사용 방법:
#   1. 이 파일을 복사: cp .env.example .env
#   2. 아래 값을 실제 키로 교체
#   3. dotenv 설치: npm install dotenv --save-dev
#   4. 실제 API 테스트: node tests/run-all-tests.js --live
#
# .env 파일은 .gitignore에 등록되어 있어 Git에 올라가지 않습니다.
# ================================================

# Mouser API Key (https://www.mouser.com/api-hub/ 에서 발급)
MOUSER_API_KEY=your_mouser_api_key_here

# Digikey API (https://developer.digikey.com 에서 발급 — 아직 없으면 비워두세요)
DIGIKEY_CLIENT_ID=your_digikey_client_id_here
DIGIKEY_CLIENT_SECRET=your_digikey_client_secret_here
